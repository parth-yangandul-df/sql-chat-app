# =============================================================================
# QueryWise — Environment Variables
# =============================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Uncomment ONE LLM provider block below and fill in your key(s)
# 3. Run:              docker compose -f docker-compose.share.yml up
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false


# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Fernet key used to encrypt stored database connection strings.
# Generate your own:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=dev-encryption-key-change-in-production

# Allowed CORS origins (JSON list). Add your domain if deploying remotely.
CORS_ORIGINS=["http://localhost:5173"]


# -----------------------------------------------------------------------------
# LLM Provider — uncomment exactly ONE block
# -----------------------------------------------------------------------------

# ---- Option 1: OpenAI (recommended) ----------------------------------------
# DEFAULT_LLM_PROVIDER=openai
# DEFAULT_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# ---- Option 2: Anthropic ----------------------------------------------------
# Anthropic has no embedding API — OpenAI key is required for embeddings.
# DEFAULT_LLM_PROVIDER=anthropic
# DEFAULT_LLM_MODEL=claude-sonnet-4-5-20250929
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# ---- Option 3: Ollama (local, no API key needed) ----------------------------
# Run Ollama natively on your machine, then start the stack.
# Pull models first:  ollama pull llama3.1:8b && ollama pull nomic-embed-text
# DEFAULT_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text # locally pulled
# EMBEDDING_DIMENSION=768

# ---- Option 4: OpenRouter (300+ models, OpenAI-compatible) ------------------
# OpenRouter has no embedding API — OpenAI key is required for embeddings.
# DEFAULT_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536


# -----------------------------------------------------------------------------
# Query Defaults
# -----------------------------------------------------------------------------
DEFAULT_QUERY_TIMEOUT_SECONDS=30
DEFAULT_MAX_ROWS=1000
MAX_RETRY_ATTEMPTS=3


# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
MAX_QUERIES_PER_MINUTE=30


# -----------------------------------------------------------------------------
# Context Builder
# -----------------------------------------------------------------------------
MAX_CONTEXT_TABLES=8
MAX_SAMPLE_QUERIES=3


# -----------------------------------------------------------------------------
# Sample Database Auto-Setup
# -----------------------------------------------------------------------------
# Set to true only if you have a sample-db service configured.
AUTO_SETUP_SAMPLE_DB=false

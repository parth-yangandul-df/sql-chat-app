# E2E test environment configuration
# Copy this file to .env.e2e and fill in real values before running:
#   pytest backend/tests/e2e -v

# Base URL of the running QueryWise backend
E2E_BASE_URL=http://localhost:8000

# Admin user (needs 'admin' role)
E2E_ADMIN_EMAIL=admin@querywise.local
E2E_ADMIN_PASSWORD=changeme

# Regular user (any role)
E2E_USER_EMAIL=user@querywise.local
E2E_USER_PASSWORD=changeme

# UUID of a configured and active DatabaseConnection to run query tests against
# Leave empty to skip all query/session/history tests
E2E_CONNECTION_ID=
